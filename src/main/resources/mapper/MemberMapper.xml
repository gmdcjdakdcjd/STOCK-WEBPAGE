<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.stock.webpage.mapper.MemberMapper">

    <!-- =========================
         member 조회
         ========================= -->

    <!-- MID 조회 -->
    <select id="selectMemberByMid" resultType="MemberDto">
        SELECT
            mid,
            mpw,
            email,
            del,
            social,
            grade
        FROM member
        WHERE mid = #{mid}
    </select>

    <!-- EMAIL 조회 -->
    <select id="selectMemberByEmail" resultType="MemberDto">
        SELECT
            mid,
            mpw,
            email,
            del,
            social,
            grade
        FROM member
        WHERE email = #{email}
    </select>

    <!-- MID 또는 EMAIL 조회 (로그인용) -->
    <select id="selectMemberByMidOrEmail"
            parameterType="string"
            resultType="MemberDto">
        SELECT
            mid,
            mpw,
            email,
            del,
            social,
            grade
        FROM member
        WHERE mid = #{keyword}
           OR email = #{keyword}
    </select>

    <!-- =========================
         member insert
         ========================= -->
    <insert id="insertMember">
        INSERT INTO member (
            mid,
            mpw,
            email,
            del,
            social,
            grade
        ) VALUES (
                     #{mid},
                     #{mpw},
                     #{email},
                     #{del},
                     #{social},
                     #{grade}
                 )
    </insert>

    <!-- =========================
         password update
         ========================= -->
    <update id="updatePassword">
        UPDATE member
        SET mpw = #{mpw}
        WHERE mid = #{mid}
    </update>

    <!-- =========================
         roles
         ========================= -->
    <select id="selectRolesByMid" resultType="string">
        SELECT role_set
        FROM member_role_set
        WHERE member_mid = #{mid}
    </select>

    <insert id="insertRole">
        INSERT INTO member_role_set (
            member_mid,
            role_set
        ) VALUES (
                     #{mid},
                     #{role}
                 )
    </insert>

    <delete id="deleteRolesByMid">
        DELETE FROM member_role_set
        WHERE member_mid = #{mid}
    </delete>

    <!-- =========================
         관리자 전용 기능 (회원 관리)
         ========================= -->

    <!-- 전체 회원 조회 -->
    <select id="selectAllMembers" resultType="MemberDto">
        SELECT
            mid,
            mpw,
            email,
            del,
            social,
            grade
        FROM member
        ORDER BY mid ASC
    </select>

    <!-- 회원 등급 수정 -->
    <update id="updateMemberGrade">
        UPDATE member
        SET grade = #{grade}
        WHERE mid = #{mid}
    </update>

    <!-- 회원 탈퇴 (del 상태 변경) -->
    <update id="updateDelStatus">
        UPDATE member
        SET del = 1
        WHERE mid = #{mid}
    </update>

    <!-- 이메일 정보 변경 -->
    <update id="updateEmail">
        UPDATE member
        SET email = #{email}
        WHERE mid = #{mid}
    </update>

</mapper>
